{
  "name": "theme",
  "version": "3.8.0",
  "description": "",
  "scripts": {
    "start": "npm run dev",
    "build": "npm run build:clean && npm run build:tailwind",
    "build:clean": "rimraf ./src/apps/static/css/dist",
    "build:tailwind": "cross-env NODE_ENV=production npx @tailwindcss/cli -i ./styles.css -o ./src/apps/static/css/dist/styles.css --minify",
    "dev": "cross-env NODE_ENV=development npx @tailwindcss/cli -i ./styles.css -o ./src/apps/static/css/dist/styles.css -w",
    "tailwindcss": "node ./node_modules/tailwindcss/lib/cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.11",
    "cross-env": "^7.0.3",
    "daisyui": "^5.0.46",
    "rimraf": "^5.0.5",
    "tailwindcss": "^4.1.11"
  }
}
