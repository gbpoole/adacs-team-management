
# Security Warning! Do not commit this file to any VCS!
# This is a local file to speed up development process,
# so you don't have to change your environment variables.
#
# This is not applied to `.env.template`!
# Template files must be committed to the VCS, but must not contain
# any secret values.


# === General ===

DOMAIN_NAME=test-project.org


# === Django ===

# Generate yours with:
# python3 -c 'from django.utils.crypto import get_random_string; print(get_random_string(50))'
DJANGO_SECRET_KEY=__CHANGEME__
DJANGO_DEBUG=True
DJANGO_TIMEZONE=Australia/Melbourne
# Override trusted CSRF origins (comma-separated). Defaults include https://<DOMAIN_NAME>,
# http://localhost:8000 and http://localhost for local Docker testing.
# CSRF_TRUSTED_ORIGINS=https://example.com,http://localhost:8000



# === DATABASE ===

# These variables are special, since they are consumed
# by both django and mysql docker image.
# Cannot be renamed if you use mysql in docker.
# See: https://hub.docker.com/_/mysql

MYSQL_ROOT_PASSWORD=__CHANGEME__
MYSQL_DATABASE=adacs_team_management
MYSQL_USER=adacs_team_management
MYSQL_PASSWORD=adacs_team_management_password

DJANGO_MYSQL_HOST=localhost
DJANGO_MYSQL_PORT=3306

# === EMAIL ===
EMAIL_HOST=mailpit
EMAIL_PORT=1025

# === RECAPTCHA ===
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

